rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUserProfile(data) {
      return data.username is string && data.username.size() <= 100
        && data.email is string && data.email.size() <= 200
        && data.fullName is string && data.fullName.size() <= 200
        && data.phone is string && data.phone.size() <= 50
        && data.photoUrl is string && data.photoUrl.size() <= 1000
        && data.dailyGoal is number && data.dailyGoal >= 0 && data.dailyGoal <= 50000
        && data.level is number && data.level >= 0
        && data.xp is number && data.xp >= 0
        && data.streak is number && data.streak >= 0
        && data.language is string && data.language.size() <= 10
        && data.theme is string && data.theme.size() <= 50
        && data.font is string && data.font.size() <= 50;
    }

    function isValidWaterRecord(data) {
      return data.id is string && data.id.size() <= 128
        && data.category is string && data.category.size() <= 100
        && data.liters is number && data.liters >= 0 && data.liters <= 10000
        && data.date is string && data.date.size() <= 20
        && data.time is string && data.time.size() <= 10
        && data.note is string && data.note.size() <= 1000;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow delete: if false;

      match /records/{recordId} {
        allow get, list: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(recordId) && isValidWaterRecord(request.resource.data);
        allow delete: if isOwner(userId) && isValidId(recordId);
      }
    }
  }
}
